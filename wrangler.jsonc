{
  "name": "job-hunting-rag",
  "main": "worker/index.js",
  "compatibility_date": "2025-05-01",
  "containers": [
    {
      "class_name": "JobRagContainer",
      "image": "./Dockerfile",
      "max_instances": 1,
      "instance_type": "basic"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "JOB_RAG",
        "class_name": "JobRagContainer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["JobRagContainer"]
    }
  ]
}
